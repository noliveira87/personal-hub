{
  "name": "personal-hub-monorepo",
  "version": "1.0.0",
  "description": "Unified personal management hub",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/warranties",
    "packages/portfolio",
    "packages/home-contracts",
    "packages/libs/ui"
  ],
  "scripts": {
    "dev": "npm --prefix packages/warranties run dev -- --port 8081",
    "build": "npm --prefix packages/warranties run build",
    "build:all": "npm run build && npm --prefix packages/portfolio run build && npm --prefix packages/home-contracts run build",
    "test": "npm --prefix packages/warranties run test",
    "lint": "npm --prefix packages/warranties run lint",
    "dev:portfolio": "npm --prefix packages/portfolio run dev -- --port 8080",
    "dev:home-contracts": "npm --prefix packages/home-contracts run dev -- --port 8083"
  }
}
